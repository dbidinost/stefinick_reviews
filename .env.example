SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — leave blank to use SQLite in development
DATABASE_URL=

# TMDB API key (https://developer.themoviedb.org/)
TMDB_API_KEY=your-tmdb-api-key-here
# TMDB language for titles and synopses (default: en-US, use it-IT for Italian)
TMDB_LANGUAGE=en-US

# Google Books API key (https://console.cloud.google.com/ → enable Books API)
GOOGLE_BOOKS_API_KEY=

# Invite code for new-user registration (default: friends2025)
INVITE_CODE=friends2026

# Optional: site URL for emails / absolute links
SITE_URL=http://localhost:8000
